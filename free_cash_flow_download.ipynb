   "source": [
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "\n",
    "# Create ticker object\n",
    "tcs = yf.Ticker(\"TCS.NS\")\n",
    "\n",
    "# Download cash flow statement\n",
    "cashflow = tcs.cashflow\n",
    "\n",
    "# Display\n",
    "print(cashflow)\n",
    "\n",
    "# Save to Excel\n",
    "cashflow.to_excel(\"TCS_CashFlow.xlsx\")\n",
    "\n",
    "print(\"Excel file saved successfully!\")"
   ]
